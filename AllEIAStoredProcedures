CREATE PROCEDURE EIA.usp_MergeEIA860Master
AS
BEGIN
    SET NOCOUNT ON;
    EXEC EIA.usp_MergeEIA860PlantData;
    EXEC EIA.usp_MergeEIA860UtilityData;
    EXEC EIA.usp_MergeEIA860GeneratorData;
    EXEC EIA.usp_MergeEIA860WindData;
