-- ============================================================
-- SP: Master - Calls All Individual SPs
-- ============================================================
IF EXISTS (SELECT * FROM sys.procedures p JOIN sys.schemas s ON p.schema_id = s.schema_id
           WHERE p.name = 'usp_MergeEIA860Master' AND s.name = 'EIA')
    DROP PROCEDURE EIA.usp_MergeEIA860Master;
