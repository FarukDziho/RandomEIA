-- ============================================================
-- Table 1: Main Plant Data Table
-- ============================================================
IF NOT EXISTS (SELECT * FROM sys.tables t 
               JOIN sys.schemas s ON t.schema_id = s.schema_id
               WHERE t.name = 'EIA860_PlantData' AND s.name = 'EIA')
BEGIN
    CREATE TABLE EIA.EIA860_PlantData (
        Id                  INT IDENTITY(1,1) PRIMARY KEY,
        ReportYear          INT,
        UtilityId           NVARCHAR(50),
        UtilityName         NVARCHAR(255),
        PlantCode           NVARCHAR(50),
        PlantName           NVARCHAR(255),
        StreetAddress       NVARCHAR(255),
        City                NVARCHAR(100),
        State               NVARCHAR(10),
        Zip                 NVARCHAR(20),
        County              NVARCHAR(100),
        Latitude            NVARCHAR(50),
        Longitude           NVARCHAR(50),
        NercRegion          NVARCHAR(50),
        BalancingAuthority  NVARCHAR(100),
        WaterSource         NVARCHAR(255),
        PrimaryPurpose      NVARCHAR(100),
        LoadedAt            DATETIME DEFAULT GETDATE()
    );
    PRINT 'Created table: EIA.EIA860_PlantData';
END
ELSE
    PRINT 'Table already exists: EIA.EIA860_PlantData';
GO

