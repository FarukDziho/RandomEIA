-- ============================================================
-- Unique Constraint on Main Table
-- ============================================================
IF NOT EXISTS (
    SELECT * FROM sys.indexes 
    WHERE name = 'UQ_EIA860_Plant' 
    AND object_id = OBJECT_ID('EIA.EIA860_PlantData'))
BEGIN
    ALTER TABLE EIA.EIA860_PlantData
    ADD CONSTRAINT UQ_EIA860_Plant 
    UNIQUE (ReportYear, PlantCode);
    PRINT 'Created unique constraint: UQ_EIA860_Plant';
END
ELSE
    PRINT 'Unique constraint already exists: UQ_EIA860_Plant';
GO

-- ============================================================
-- Stored Procedure: Merge Staging into Main Table
-- ============================================================
IF EXISTS (SELECT * FROM sys.procedures p
           JOIN sys.schemas s ON p.schema_id = s.schema_id
           WHERE p.name = 'usp_MergeEIA860PlantData' AND s.name = 'EIA')
    DROP PROCEDURE EIA.usp_MergeEIA860PlantData;
GO

CREATE PROCEDURE EIA.usp_MergeEIA860PlantData
AS
BEGIN
    SET NOCOUNT ON;

    DECLARE @InsertCount  INT = 0;
    DECLARE @UpdateCount  INT = 0;
    DECLARE @SkipCount    INT = 0;
    DECLARE @StagingCount INT = 0;

    DECLARE @MergeOutput TABLE (MergeAction NVARCHAR(10));

    SELECT @StagingCount = COUNT(*) FROM EIA.EIA860_PlantData_Staging;

    MERGE EIA.EIA860_PlantData AS target
    USING EIA.EIA860_PlantData_Staging AS source
        ON target.ReportYear = source.ReportYear
        AND target.PlantCode  = source.PlantCode

    WHEN MATCHED AND (
        ISNULL(target.UtilityId,'')          != ISNULL(source.UtilityId,'')          OR
        ISNULL(target.UtilityName,'')        != ISNULL(source.UtilityName,'')        OR
        ISNULL(target.PlantName,'')          != ISNULL(source.PlantName,'')          OR
        ISNULL(target.StreetAddress,'')      != ISNULL(source.StreetAddress,'')      OR
        ISNULL(target.City,'')               != ISNULL(source.City,'')               OR
        ISNULL(target.State,'')              != ISNULL(source.State,'')              OR
        ISNULL(target.Zip,'')                != ISNULL(source.Zip,'')                OR
        ISNULL(target.County,'')             != ISNULL(source.County,'')             OR
        ISNULL(target.Latitude,'')           != ISNULL(source.Latitude,'')           OR
        ISNULL(target.Longitude,'')          != ISNULL(source.Longitude,'')          OR
        ISNULL(target.NercRegion,'')         != ISNULL(source.NercRegion,'')         OR
        ISNULL(target.BalancingAuthority,'') != ISNULL(source.BalancingAuthority,'') OR
        ISNULL(target.WaterSource,'')        != ISNULL(source.WaterSource,'')        OR
        ISNULL(target.PrimaryPurpose,'')     != ISNULL(source.PrimaryPurpose,'')
    )
    THEN UPDATE SET
        target.UtilityId          = source.UtilityId,
        target.UtilityName        = source.UtilityName,
        target.PlantName          = source.PlantName,
        target.StreetAddress      = source.StreetAddress,
        target.City               = source.City,
        target.State              = source.State,
        target.Zip                = source.Zip,
        target.County             = source.County,
        target.Latitude           = source.Latitude,
        target.Longitude          = source.Longitude,
        target.NercRegion         = source.NercRegion,
        target.BalancingAuthority = source.BalancingAuthority,
        target.WaterSource        = source.WaterSource,
        target.PrimaryPurpose     = source.PrimaryPurpose,
        target.LoadedAt           = GETDATE()

    WHEN NOT MATCHED BY TARGET
    THEN INSERT (
        ReportYear, UtilityId, UtilityName, PlantCode, PlantName,
        StreetAddress, City, State, Zip, County, Latitude, Longitude,
        NercRegion, BalancingAuthority, WaterSource, PrimaryPurpose
    )
    VALUES (
        source.ReportYear, source.UtilityId, source.UtilityName,
        source.PlantCode, source.PlantName, source.StreetAddress,
        source.City, source.State, source.Zip, source.County,
        source.Latitude, source.Longitude, source.NercRegion,
        source.BalancingAuthority, source.WaterSource, source.PrimaryPurpose
    )

    OUTPUT $action INTO @MergeOutput(MergeAction);

    SELECT
        @InsertCount = SUM(CASE WHEN MergeAction = 'INSERT' THEN 1 ELSE 0 END),
        @UpdateCount = SUM(CASE WHEN MergeAction = 'UPDATE' THEN 1 ELSE 0 END)
    FROM @MergeOutput;

    SET @SkipCount = @StagingCount - ISNULL(@InsertCount,0) - ISNULL(@UpdateCount,0);

    SELECT
        ISNULL(@InsertCount, 0)                          AS RowsInserted,
        ISNULL(@UpdateCount, 0)                          AS RowsUpdated,
        ISNULL(@SkipCount, 0)                            AS RowsSkipped,
        @StagingCount                                    AS RowsInStaging,
        (SELECT COUNT(*) FROM EIA.EIA860_PlantData)      AS TotalRowsInTable;

    TRUNCATE TABLE EIA.EIA860_PlantData_Staging;
END
GO

